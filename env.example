# ─────────────────────────────────────────────────────────────────────
# Foodint — variables de entorno
# Copia este fichero a .env y rellena con valores reales.
# .env está en .gitignore (verifica que sigue así).
# ─────────────────────────────────────────────────────────────────────

# ── Supabase (cliente — SE BUNDLEAN en el navegador) ────────────────
# Las variables VITE_* terminan en el JS final servido al navegador.
# La anon key está diseñada para ser pública, pero la URL también queda expuesta.
VITE_SUPABASE_URL=https://xzmpnchlguibclvxyynt.supabase.co
VITE_SUPABASE_ANON_KEY=

# ── Tspoon Lab (scripts Node — NUNCA se bundlean) ────────────────────
# IMPORTANTE: sin prefijo VITE_, NO entran en el bundle del navegador.
# Solo accesibles desde scripts/* y vitest.
TSPOON_USERNAME=
TSPOON_PASSWORD=
# Opcional: id del centro de coste a usar por defecto en exploración.
# Si lo omites, el script usa el primero que devuelve listOrderCenters.
TSPOON_ORDER_CENTER_ID=

# ── Supabase CLI (sólo para regenerar tipos con npm run types:gen) ──
# Personal Access Token de Supabase (NO la API key).
# Necesario sólo cuando ejecutes types:gen.
# SUPABASE_ACCESS_TOKEN=sbp_...
